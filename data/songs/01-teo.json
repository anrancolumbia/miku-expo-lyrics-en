{
  "id": "01-teo",
  "title": "テオ",
  "artist": "Omoi",
  "mode": "timed",
  "neteaseId": 492834361,
  "lines": [
    {
      "t": 22.67,
      "ja": "考えるこのままいつまで 隠しておけるかな",
      "en": ""
    },
    {
      "t": 28.28,
      "ja": "帰りたくなった時 さよならは言えるかな",
      "en": ""
    },
    {
      "t": 32.95,
      "ja": "見落としたあの日のサインが 少しずつ溶けても",
      "en": ""
    },
    {
      "t": 38.66,
      "ja": "きっと大丈夫だよ こうやって僕らまた逢えるから",
      "en": ""
    },
    {
      "t": 48.58,
      "ja": "目を閉じる",
      "en": ""
    },
    {
      "t": 49.81,
      "ja": "小さな祈りは まだ残せるかな",
      "en": ""
    },
    {
      "t": 54.24,
      "ja": "光が戾ったとき ただいまは言えるかな",
      "en": ""
    },
    {
      "t": 58.83,
      "ja": "行かなくちゃ",
      "en": ""
    },
    {
      "t": 60.2,
      "ja": "世界で一番 綺麗なものなら",
      "en": ""
    },
    {
      "t": 64.93,
      "ja": "今まで奪われてた分は",
      "en": ""
    },
    {
      "t": 67.08,
      "ja": "取り戾すまでさ!",
      "en": ""
    },
    {
      "t": 69.97,
      "ja": "もっと",
      "en": ""
    },
    {
      "t": 70.42,
      "ja": "クラクラクラ クラクラさせてよ",
      "en": ""
    },
    {
      "t": 72.94,
      "ja": "ユラユラユラ ゆらぎを見せてよ",
      "en": ""
    },
    {
      "t": 75.56,
      "ja": "キラキラキラ きらめいていてよ",
      "en": ""
    },
    {
      "t": 80.11,
      "ja": "そっと",
      "en": ""
    },
    {
      "t": 80.5,
      "ja": "傷ついた夜を呼び出してみる",
      "en": ""
    },
    {
      "t": 83.1,
      "ja": "ささやかな魔法をひとつかける",
      "en": ""
    },
    {
      "t": 85.96,
      "ja": "それだけで僕らは飛べるのさ!",
      "en": ""
    },
    {
      "t": 89.63,
      "ja": "離さないでよ! 眼差しを",
      "en": ""
    },
    {
      "t": 92.37,
      "ja": "僕達はもう 止まらないよ",
      "en": ""
    },
    {
      "t": 94.97,
      "ja": "魔法が解ける それまで",
      "en": ""
    },
    {
      "t": 97.07,
      "ja": "繋いでいてよ 手を",
      "en": ""
    },
    {
      "t": 99.36,
      "ja": "手を!",
      "en": ""
    },
    {
      "t": 100.38,
      "ja": "ひとつだって残さない",
      "en": ""
    },
    {
      "t": 102.55,
      "ja": "全てを取り戾すだけさ",
      "en": ""
    },
    {
      "t": 105.11,
      "ja": "魔法が解ける それまで",
      "en": ""
    },
    {
      "t": 107.86,
      "ja": "繋いでいてよ 手を 手を",
      "en": ""
    },
    {
      "t": 109.9,
      "ja": "手を!",
      "en": ""
