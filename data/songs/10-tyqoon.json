  "lines": [
    {
      "t": 1.34,
      "ja": "四角四面でいらんなくてごめん",
      "en": ""
    },
    {
      "t": 4.19,
      "ja": "全能のクセして限界だ、ごめん",
      "en": ""
    },
    {
      "t": 6.92,
      "ja": "未だ来ない未来に酔い痴れてたら",
      "en": ""
    },
    {
      "t": 9.87,
      "ja": "アニメ化の波に飲まれました",
      "en": ""
    },
    {
      "t": 12.93,
      "ja": "中心から離れるほどに強くなる力にただ抗って",
      "en": ""
    },
    {
      "t": 15.92,
      "ja": "殿堂へ登るのも実家で寝るのも全てがあなた次第で",
      "en": ""
    },
    {
      "t": 18.75,
      "ja": "1だけ聞いたら10知るあなたに3000くらい語って",
      "en": ""
    },
    {
      "t": 21.61,
      "ja": "健康を見せるのも優雅でいるのも興味がないもんで",
      "en": ""
    },
    {
      "t": 24.7,
      "ja": "苦楽苦楽させるあやしのエゴ",
      "en": ""
    },
    {
      "t": 27.55,
      "ja": "当たっては外れてあをによし",
      "en": ""
    },
    {
      "t": 30.3,
      "ja": "倣っ給ったのね、誰かのエゴ",
      "en": ""
    },
    {
      "t": 33.07,
      "ja": "そうできないのが大君の性なんだ",
      "en": ""
    },
    {
      "t": 47.55,
      "ja": "救いは来ないぞ狂い損ない",
      "en": ""
    },
    {
      "t": 50.52,
      "ja": "桃源郷にそんな福祉は無い",
      "en": ""
    },
    {
      "t": 53.54,
      "ja": "「ああ、こんなに上手に滑るとは思わず」",
      "en": ""
    },
    {
      "t": 57.24,
      "ja": "と、言いたげ　無彩色",
      "en": ""
    },
    {
      "t": 59.5,
      "ja": "伝わるほうへ伝わればいいとか言ったがアレは違くて",
      "en": ""
    },
    {
      "t": 62.45,
      "ja": "戦争が起きるのも何派が在るのも結構どうでもよくて",
      "en": ""
    },
    {
      "t": 65.37,
      "ja": "1から「あ」なり「A」なり産める可能性だけが自慢で",
      "en": ""
    },
    {
      "t": 68.14,
      "ja": "台風の目とかいう「空っぽ」が僕の夢です！",
      "en": ""
    },
    {
      "t": 70.36,
      "ja": "なんて叫んでら",
      "en": ""
    },
    {
      "t": 71.52,
      "ja": "ﾀﾋ死にたいあなたに共感はしないが",
      "en": ""
    },
    {
      "t": 74.08,
      "ja": "何となく感じ入ったげるわ",
      "en": ""
    },
    {
      "t": 76.8,
      "ja": "そんなあなたは冥土へも行けず",
      "en": ""
    },
    {
      "t": 79.81,
      "ja": "飯田も数子も言うはずだわ",
      "en": ""
    },
    {
      "t": 82.73,
      "ja": "ﾀﾋ死にたいあなたに共感はしないが",
