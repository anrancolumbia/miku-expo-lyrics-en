  "lines": [
    {
      "t": 16.67,
      "ja": "理想を投げ捨てた荒野",
      "en": ""
    },
    {
      "t": 24.32,
      "ja": "あざとく後悔を見世物にして",
      "en": ""
    },
    {
      "t": 32.16,
      "ja": "見飽きた愛の物語",
      "en": ""
    },
    {
      "t": 39.87,
      "ja": "また誰かの影 重ねてる",
      "en": ""
    },
    {
      "t": 47.67,
      "ja": "平和のために争いを繰り返す矛盾",
      "en": ""
    },
    {
      "t": 51.45,
      "ja": "貫くほど確かな意志もなく",
      "en": ""
    },
    {
      "t": 55.28,
      "ja": "人それぞれの正義から生まれた理屈で",
      "en": ""
    },
    {
      "t": 59.19,
      "ja": "妬み 戸惑い 驕り 哀れみ 飛び交ってゆく",
      "en": ""
    },
    {
      "t": 62.77,
      "ja": "今日も同じ罪で踊り続けて",
      "en": ""
    },
    {
      "t": 66.62,
      "ja": "明日も誤解の連鎖 巡り廻りゆくの",
      "en": ""
    },
    {
      "t": 70.71,
      "ja": "さぁ手を取り合い果てに向かおう",
      "en": ""
    },
    {
      "t": 74.36,
      "ja": "いずれ散る旅路でも 望まずにはいられない",
      "en": ""
    },
    {
      "t": 78.59,
      "ja": "永遠なんて 嘘にもならない戯言",
      "en": ""
    },
    {
      "t": 86.2,
      "ja": "偽りの未来も 過ちの歴史も",
      "en": ""
    },
    {
      "t": 90.19,
      "ja": "祈る術を間違えた 祈り",
      "en": ""
    },
    {
      "t": 119.33,
      "ja": "舞台で立ち尽くす道化",
      "en": ""
    },
    {
      "t": 126.91,
      "ja": "安物の悲劇 売り物にして",
      "en": ""
    },
    {
      "t": 134.65,
      "ja": "乾いた観衆の拍手",
      "en": ""
    },
    {
      "t": 142.39,
      "ja": "響く笑い声 種明かし",
      "en": ""
    },
    {
      "t": 150.19,
      "ja": "憎しみが生む憎しみに翻弄されては",
      "en": ""
    },
    {
      "t": 154.01,
      "ja": "掴んだはずの答えを見失い",
      "en": ""
    },
    {
      "t": 157.91,
      "ja": "孤独を背負い生きていく人の世の運命",
      "en": ""
    },
    {
      "t": 161.74,
      "ja": "戻れない日々 進めない先 ここじゃない場所",
      "en": ""
    },
    {
      "t": 165.33,
      "ja": "夢を追い求めて見過ごしたもの",
      "en": ""
    },
    {
      "t": 169.26,
      "ja": "淡い記憶の中 君が手を振る景色",
      "en": ""
    },
    {
      "t": 173.35,
      "ja": "ねぇ僕がいつか辿り着いたら",
      "en": ""
    },
    {
      "t": 176.99,
      "ja": "あの日触れられなかった 髪に埋もれたいんだ",
      "en": ""
    },
    {
      "t": 181.19,
      "ja": "抗うように消えゆく 情熱の終焉",
      "en": ""
    },
    {
      "t": 188.85,
      "ja": "幸福の在り処は 愛された証は",
      "en": ""
    },
    {
      "t": 192.76,
      "ja": "胸の奥底で揺れる光",
      "en": ""
    },
    {
      "t": 198.55,
      "ja": "数え切れない こじつけの上塗り",
      "en": ""
    },
    {
      "t": 205.41,
      "ja": "せめて結末だけは二人で",
      "en": ""
    },
    {
      "t": 213.77,
      "ja": "今日も同じ罪で踊り続けて",
      "en": ""
