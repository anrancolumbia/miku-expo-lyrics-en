  "lines": [
    {
      "t": 49.98,
      "ja": "ふと旅に出たくなるように　ヒトは皆",
      "en": ""
    },
    {
      "t": 58.24,
      "ja": "眠る場所を求めるものだと　君は云うけど―。",
      "en": ""
    },
    {
      "t": 66.7,
      "ja": "僕が\"終末\"を知ったときには　此処はもう",
      "en": ""
    },
    {
      "t": 75.31,
      "ja": "暖かくも寒くもない速度で落ちていた",
      "en": ""
    },
    {
      "t": 94.34,
      "ja": "\"カミサマ\"が　もしも居たとしても",
      "en": ""
    },
    {
      "t": 102.19,
      "ja": "大きな空　溢れるほどの虹　架けてくれなくても良い",
      "en": ""
    },
    {
      "t": 110.81,
      "ja": "『唯一つ　願いをかけるとしたら…？』",
      "en": ""
    },
    {
      "t": 117.93,
      "ja": "君のもとへ\"うた\"を届けたい",
      "en": ""
    },
    {
      "t": 121.68,
      "ja": "メグル　メグル　最後の　廻音（メロディ）",
      "en": ""
    },
    {
      "t": 127.68,
      "ja": "君が笑ってくれるのなら　僕は",
      "en": ""
    },
    {
      "t": 132.8,
      "ja": "消えてしまっても　構わないから",
      "en": ""
    },
    {
      "t": 136.25,
      "ja": "君が涙の海に身を投げても",
      "en": ""
    },
    {
      "t": 141.21,
      "ja": "握りしめた手　離さないから",
      "en": ""
    },
    {
      "t": 144.69,
      "ja": "白い嘘だらけの世界なんてもう",
      "en": ""
    },
    {
      "t": 149.4,
      "ja": "消えてしまっても　構わないから",
      "en": ""
    },
    {
      "t": 153.01,
      "ja": "『旅の終わりの夢に見た存在（もの）に　僕は－",
      "en": ""
    },
    {
      "t": 159.41,
      "ja": "なれますように　なれますように』",
      "en": ""
    },
    {
